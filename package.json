{
  "name": "planora-backend",
  "version": "1.0.0",
  "description": "Planora AI — production API (domain architecture)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node --transpile-only src/server.ts",
    "watch": "nodemon src/server.ts",
    "build": "tsc",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "postinstall": "prisma generate || echo Prisma generate skipped - run npm run db:generate after install",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:generate:win-ssl": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 prisma generate",
    "db:studio": "prisma studio",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "@sentry/node": "^10.60.0",
    "@sentry/profiling-node": "^10.60.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^4.15.4",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^12.7.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.16",
    "openai": "^4.104.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^9.0.7",
    "cross-env": "^7.0.3",
    "prisma": "6.19.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
